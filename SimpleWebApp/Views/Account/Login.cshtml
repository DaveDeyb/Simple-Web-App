@model SimpleWebApp.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    ViewData["HideChrome"] = true;
}

<div class="tn-auth-page">
    <div class="tn-auth-wrap">
        <div class="tn-auth-head">
            <a asp-controller="Home" asp-action="Index" class="tn-auth-logo">
                <img src="~/img/logo.svg" alt="Time Nest Logo" />
            </a>
            <a asp-controller="Home" asp-action="Index" class="tn-back-btn">← Back</a>
            <h1>Welcome Back</h1>
            <p>Sign in to your Time Nest account</p>
        </div>

        <div class="tn-auth-card">
            <form asp-action="Login" method="post" class="tn-auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div>
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control tn-input" placeholder="you@example.com" maxlength="254" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="Password" class="form-label"></label>
                    <div class="tn-password-wrap">
                        <input asp-for="Password" class="form-control tn-input tn-password-input" placeholder="Enter your password" maxlength="128" />
                        <button type="button" class="tn-password-toggle" data-target="Password" aria-label="Show password" aria-pressed="false">
                            <span class="tn-eye-icon tn-eye-open" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </span>
                            <span class="tn-eye-icon tn-eye-closed" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="m3 3 18 18"></path>
                                    <path d="M10.58 10.58a2 2 0 0 0 2.83 2.83"></path>
                                    <path d="M9.88 5.09A10.94 10.94 0 0 1 12 5c7 0 11 7 11 7a21.86 21.86 0 0 1-2.16 3.19"></path>
                                    <path d="M6.61 6.61A21.84 21.84 0 0 0 1 12s4 7 11 7a10.94 10.94 0 0 0 4.23-.85"></path>
                                </svg>
                            </span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="tn-auth-row">
                    <label class="form-check-label tn-remember">
                        <input asp-for="RememberMe" class="form-check-input" />
                        Remember me
                    </label>
                    <a href="#" class="tn-link">Forgot password?</a>
                </div>

                <button type="submit" class="tn-btn tn-btn-primary tn-full">Sign In</button>
            </form>
        </div>

        <p class="tn-auth-bottom">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register">Sign up</a>
        </p>
    </div>
</div>

<style>
.tn-password-wrap {
    position: relative;
}

.tn-password-input {
    padding-right: 3rem;
}

.tn-password-toggle {
    position: absolute;
    right: 0.55rem;
    top: 50%;
    transform: translateY(-50%);
    border: 1px solid #cddcf6;
    background: #f8fbff;
    color: #1d4ed8;
    border-radius: 0.55rem;
    width: 2.05rem;
    height: 2.05rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
}

.tn-password-toggle:hover {
    background: #eef5ff;
}

.tn-eye-icon {
    display: inline-flex;
}

.tn-eye-closed {
    display: none;
}

.tn-password-toggle.is-revealed .tn-eye-open {
    display: none;
}

.tn-password-toggle.is-revealed .tn-eye-closed {
    display: inline-flex;
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.tn-password-toggle').forEach(function (button) {
                button.addEventListener('click', function () {
                    const targetId = button.getAttribute('data-target');
                    const input = document.getElementById(targetId);
                    if (!input) {
                        return;
                    }

                    const reveal = input.type === 'password';
                    input.type = reveal ? 'text' : 'password';
                    button.classList.toggle('is-revealed', reveal);
                    button.setAttribute('aria-pressed', reveal ? 'true' : 'false');
                    button.setAttribute('aria-label', reveal ? 'Hide password' : 'Show password');
                });
            });
        });
    </script>
}
