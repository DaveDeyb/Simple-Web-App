@model SimpleWebApp.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    ViewData["HideChrome"] = true;
}

<div class="tn-auth-page">
    <div class="tn-auth-wrap">
        <div class="tn-auth-head">
            <a asp-controller="Home" asp-action="Index" class="tn-auth-logo">🕐</a>
            <h1>Welcome Back</h1>
            <p>Sign in to your Time Nest account</p>
        </div>

        <div class="tn-auth-card">
            <form asp-action="Login" method="post" class="tn-auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div>
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control tn-input" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control tn-input" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="tn-auth-row">
                    <label class="form-check-label tn-remember">
                        <input asp-for="RememberMe" class="form-check-input" />
                        Remember me
                    </label>
                    <a href="#" class="tn-link">Forgot password?</a>
                </div>

                <button type="submit" class="tn-btn tn-btn-primary tn-full">Sign In</button>

                <div class="tn-divider"><span>Or continue with</span></div>
                <button type="button" class="tn-btn tn-btn-outline tn-full">Google</button>
            </form>
        </div>

        <p class="tn-auth-bottom">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register">Sign up</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
