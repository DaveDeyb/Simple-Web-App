@model AdminGroupsViewModel

@{
    ViewData["Title"] = "Group Management";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="tn-admin-groups">
    <div class="tn-admin-panel">
        <div class="tn-panel-header">
            <h2>Group Management</h2>
            <button type="button" class="tn-btn-primary" data-bs-toggle="modal" data-bs-target="#createGroupModal">
                ➕ Create Group
            </button>
        </div>

        <!-- Groups List -->
        <div class="tn-groups-grid">
            @if (Model.Groups.Count == 0)
            {
                <div class="tn-empty-state">
                    <p>No groups yet. <a href="#" data-bs-toggle="modal" data-bs-target="#createGroupModal">Create one to get started!</a></p>
                </div>
            }
            else
            {
                @foreach (var group in Model.Groups)
                {
                    <div class="tn-group-card">
                        <div class="tn-group-header">
                            <h3>@group.Name</h3>
                            <div class="tn-group-actions">
                                <a asp-action="GroupDetails" asp-route-id="@group.Id" class="tn-icon-btn" title="View Details">👁️</a>
                                <form method="post" asp-action="DeleteGroup" asp-route-id="@group.Id" style="display:inline;padding:0;margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="tn-icon-btn tn-danger" onclick="return confirm('Delete this group?')" title="Delete">🗑️</button>
                                </form>
                            </div>
                        </div>

                        <p class="tn-group-description">@group.Description</p>

                        <div class="tn-group-info">
                            <span>👤 Owner: @group.Owner?.FullName</span>
                            <span>👥 Members: @group.Members.Count</span>
                        </div>

                        <div class="tn-group-members">
                            @if (group.Members.Count == 0)
                            {
                                <p class="tn-empty-members">No members yet</p>
                            }
                            else
                            {
                                <ul>
                                    @foreach (var member in group.Members.Take(3))
                                    {
                                        <li>
                                            <span class="tn-member-avatar">@member.User?.FullName.First()</span>
                                            <span>@member.User?.FullName</span>
                                        </li>
                                    }
                                    @if (group.Members.Count > 3)
                                    {
                                        <li class="tn-more-members">+@(group.Members.Count - 3) more</li>
                                    }
                                </ul>
                            }
                        </div>

                        <a asp-action="GroupDetails" asp-route-id="@group.Id" class="tn-btn-secondary">Manage Group →</a>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Create Group Modal -->
<div class="modal fade" id="createGroupModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content tn-modal">
            <div class="modal-header tn-modal-header">
                <h5 class="modal-title">Create New Group</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="CreateGroup">
                @Html.AntiForgeryToken()
                <div class="modal-body tn-modal-body">
                    <div class="mb-3">
                        <label for="groupName" class="form-label">Group Name</label>
                        <input type="text" id="groupName" name="name" class="form-control" required placeholder="e.g., Development Team" />
                    </div>
                    <div class="mb-3">
                        <label for="groupDescription" class="form-label">Description</label>
                        <textarea id="groupDescription" name="description" class="form-control" placeholder="Optional group description"></textarea>
                    </div>
                </div>
                <div class="modal-footer tn-modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Group</button>
                </div>
            </form>
        </div>
    </div>
</div>
