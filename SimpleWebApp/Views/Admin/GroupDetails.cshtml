@model AdminGroupDetailsViewModel

@{
    ViewData["Title"] = $"Group: {Model.Group?.Name}";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="tn-admin-group-details">
    <a href="javascript:history.back()" class="tn-back-link">← Back to Groups</a>

    <div class="tn-admin-panel">
        <!-- Group Header -->
        <div class="tn-group-detail-header">
            <div>
                <h1>@Model.Group?.Name</h1>
                <p class="tn-group-meta">
                    Owner: <strong>@Model.Group?.Owner?.FullName</strong> | 
                    Created: <strong>@Model.Group?.CreatedAt.ToString("MMM dd, yyyy")</strong>
                </p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Group?.Description))
        {
            <p class="tn-group-detail-description">@Model.Group.Description</p>
        }

        <!-- Members Section -->
        <div class="tn-group-section">
            <div class="tn-section-header">
                <h2>Group Members (@Model.Group?.Members.Count)</h2>
                @if (Model.AvailableUsers.Count > 0)
                {
                    <button type="button" class="tn-btn-secondary" data-bs-toggle="modal" data-bs-target="#addMemberModal">
                        ➕ Add Member
                    </button>
                }
            </div>

            @if (Model.Group?.Members.Count == 0)
            {
                <p class="tn-empty-message">No members in this group yet</p>
            }
            else
            {
                <div class="tn-members-list">
                    @foreach (var member in Model.Group!.Members)
                    {
                        <div class="tn-member-item">
                            <span class="tn-member-avatar">@member.User?.FullName.First()</span>
                            <div class="tn-member-info">
                                <div class="tn-member-name">@member.User?.FullName</div>
                                <div class="tn-member-email">@member.User?.Email</div>
                            </div>
                            <form method="post" asp-action="RemoveUserFromGroup" asp-route-groupId="@Model.Group.Id" asp-route-userId="@member.UserId" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="tn-btn-danger-small" onclick="return confirm('Remove this member?')">Remove</button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Add Member Modal -->
@if (Model.AvailableUsers.Count > 0)
{
    <div class="modal fade" id="addMemberModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content tn-modal">
                <div class="modal-header tn-modal-header">
                    <h5 class="modal-title">Add Member to Group</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-action="AddUserToGroup">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="groupId" value="@Model.Group?.Id" />
                    <div class="modal-body tn-modal-body">
                        <label for="userId" class="form-label">Select User</label>
                        <select id="userId" name="userId" class="form-control" required>
                            <option value="">-- Choose a user --</option>
                            @foreach (var user in Model.AvailableUsers)
                            {
                                <option value="@user.Id">@user.FullName (@user.Email)</option>
                            }
                        </select>
                    </div>
                    <div class="modal-footer tn-modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Member</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
