@{
    ViewData["Title"] = "Time Nest";
    ViewData["HideChrome"] = true;
}

<div class="tn-landing">
    <nav class="tn-landing-nav">
        <div class="tn-nav-left">
            <div class="tn-logo-mark">
                <img src="~/img/logo.svg" alt="Time Nest Logo" />
            </div>
            <span>Time Nest</span>
        </div>
        <div class="tn-nav-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="tn-nav-link" asp-controller="TimeEntries" asp-action="Index">Dashboard</a>
                <form method="post" asp-controller="Account" asp-action="Logout">
                    <button type="submit" class="tn-btn tn-btn-primary">Logout</button>
                </form>
            }
            else
            {
                <a class="tn-nav-link" asp-controller="Account" asp-action="Login">Login</a>
                <a class="tn-btn tn-btn-primary" asp-controller="Account" asp-action="Register">Sign Up</a>
            }
        </div>
    </nav>

    <section class="tn-hero">
        <h1>Track Time. <span>Boost Productivity.</span></h1>
        <p>Time Nest helps teams track work hours, manage projects, and gain insights into productivity.</p>
        <div class="tn-hero-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="tn-btn tn-btn-primary" asp-controller="TimeEntries" asp-action="Index">Open Dashboard</a>
            }
            else
            {
                <a class="tn-btn tn-btn-primary" asp-controller="Account" asp-action="Register">Start Free Trial</a>
                <a class="tn-btn tn-btn-outline" asp-controller="Account" asp-action="Login">Login</a>
            }
        </div>
    </section>

    <section class="tn-features">
        <h2>Powerful Features</h2>
        <div class="tn-feature-grid">
            <article><h3>Real-Time Tracking</h3><p>Clock in and out quickly with reliable logs.</p></article>
            <article><h3>Insightful Analytics</h3><p>View trends and hours with clear dashboard visuals.</p></article>
            <article><h3>Team Management</h3><p>See who is in, on break, or out at a glance.</p></article>
            <article><h3>Project Tracking</h3><p>Understand where team hours are spent across projects.</p></article>
            <article><h3>Automated Reports</h3><p>Use activity history for weekly and monthly reporting.</p></article>
            <article><h3>Cloud Ready</h3><p>Hosted on Azure with monitoring and database integration.</p></article>
        </div>
    </section>

    <section class="tn-stats">
        <div><strong>10K+</strong><span>Teams Tracking Time</span></div>
        <div><strong>50M+</strong><span>Hours Tracked</span></div>
        <div><strong>150+</strong><span>Countries</span></div>
        <div><strong>99.9%</strong><span>Uptime</span></div>
    </section>

    <section class="tn-cta">
        <h2>Ready to Get Started?</h2>
        <p>Join teams using Time Nest to boost efficiency.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="tn-btn tn-btn-primary" asp-controller="TimeEntries" asp-action="Index">Go to Dashboard</a>
        }
        else
        {
            <a class="tn-btn tn-btn-primary" asp-controller="Account" asp-action="Register">Create Free Account</a>
        }
    </section>

    <footer class="tn-landing-footer">
        <p>&copy; 2026 Time Nest. All rights reserved.</p>
    </footer>
</div>
