@{
    ViewData["Title"] = "Home";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="text-center">
        <h1 class="display-5">Welcome back</h1>
        <p class="lead">Use the navigation bar to open your Dashboard and Timesheet.</p>
    </div>
}
else
{
    <div class="text-center">
        <h1 class="display-5">Simple Time Tracker</h1>
        <p class="lead">Please login or register to access your dashboard and timesheet.</p>
        <div class="d-flex justify-content-center gap-2 mt-3">
            <a class="btn btn-primary" asp-controller="Account" asp-action="Login">Login</a>
            <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Register">Register</a>
        </div>
    </div>
}
