@model SimpleWebApp.ViewModels.TimeEntriesViewModel

@{
    ViewData["Title"] = "Dashboard";
    ViewData["FullWidth"] = true;
    ViewData["BodyClass"] = "tn-dashboard-page";

    var ascendingEntries = Model.Entries.OrderBy(e => e.Timestamp).ToList();
    var latestEntry = Model.Entries.OrderByDescending(e => e.Timestamp).FirstOrDefault();

    var status = "Clocked Out";
    if (latestEntry is not null)
    {
        status = latestEntry.EntryType.ToString() switch
        {
            "ClockIn" => "Clocked In",
            "BreakStart" => "On Break",
            "BreakEnd" => "Clocked In",
            _ => "Clocked Out"
        };
    }

    var trackedSeconds = 0d;
    DateTime? activeClockIn = null;
    DateTime? breakStart = null;

    foreach (var entry in ascendingEntries)
    {
        switch (entry.EntryType)
        {
            case SimpleWebApp.Models.TimeEntryType.ClockIn:
                activeClockIn = entry.Timestamp;
                breakStart = null;
                break;
            case SimpleWebApp.Models.TimeEntryType.BreakStart:
                if (activeClockIn.HasValue)
                {
                    trackedSeconds += (entry.Timestamp - activeClockIn.Value).TotalSeconds;
                    activeClockIn = null;
                    breakStart = entry.Timestamp;
                }
                break;
            case SimpleWebApp.Models.TimeEntryType.BreakEnd:
                if (breakStart.HasValue)
                {
                    breakStart = null;
                    activeClockIn = entry.Timestamp;
                }
                break;
            case SimpleWebApp.Models.TimeEntryType.ClockOut:
                if (activeClockIn.HasValue)
                {
                    trackedSeconds += (entry.Timestamp - activeClockIn.Value).TotalSeconds;
                    activeClockIn = null;
                }
                breakStart = null;
                break;
        }
    }

    if (activeClockIn.HasValue && Model.SelectedDate.Date == DateTime.UtcNow.Date)
    {
        trackedSeconds += (DateTime.UtcNow - activeClockIn.Value).TotalSeconds;
    }

    if (trackedSeconds < 0)
    {
        trackedSeconds = 0;
    }

    var trackedHours = trackedSeconds / 3600d;
    var trackedHoursText = trackedHours.ToString("0.0");
    var currentlyClockedIn = status == "Clocked In" || status == "On Break";
    var weekdays = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
    var selectedDayIndex = ((int)Model.SelectedDate.DayOfWeek + 6) % 7;

    var latestType = latestEntry?.EntryType;
    var canClockIn = latestType is null || latestType == SimpleWebApp.Models.TimeEntryType.ClockOut;
    var canBreak = latestType == SimpleWebApp.Models.TimeEntryType.ClockIn;
    var canResume = latestType == SimpleWebApp.Models.TimeEntryType.BreakStart;
    var canClockOut = latestType == SimpleWebApp.Models.TimeEntryType.ClockIn || latestType == SimpleWebApp.Models.TimeEntryType.BreakEnd;
}

<div class="tn-dashboard">
    <section class="tn-page-head">
        <h1>Dashboard</h1>
        <p>Monitor your team's productivity and time tracking.</p>
    </section>

    <section class="tn-filterbar">
        <div class="tn-pill-group" id="tn-timeframe">
            <button type="button" class="tn-pill active" data-frame="day">Day</button>
            <button type="button" class="tn-pill" data-frame="week">Week</button>
        </div>

        <form method="get" asp-action="Index" class="tn-date-form">
            <input class="form-control" type="date" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
            <button type="submit" class="tn-outline-btn">Load</button>
        </form>
    </section>

    <section class="tn-clock-card">
        <div>
            <h2>Your Time Clock</h2>
            <div class="tn-clock-time" id="tn-clock-time">00:00:00</div>
            <p class="tn-clock-status">
                Status:
                <span class="@(status == "Clocked In" ? "in" : status == "On Break" ? "break" : "out")">@status</span>
            </p>
            <p class="tn-clock-note">Today: @trackedHoursText hours logged</p>
        </div>
        <form method="post" asp-action="Action" class="tn-clock-actions">
            @Html.AntiForgeryToken()
            <input type="hidden" name="entryType" id="tn-entryType" value="" />
            @if (canClockIn)
            {
                <button type="submit" name="entryType" value="ClockIn" class="tn-action-btn tn-action-in">Clock In</button>
            }

            @if (canBreak)
            {
                <button type="button" class="tn-action-btn tn-action-warn tn-confirm-trigger" data-entry="BreakStart" data-message="Start break now?">Break</button>
            }

            @if (canResume)
            {
                <button type="submit" name="entryType" value="BreakEnd" class="tn-action-btn tn-action-warn">Resume</button>
            }

            @if (canClockOut)
            {
                <button type="button" class="tn-action-btn tn-action-out tn-confirm-trigger" data-entry="ClockOut" data-message="Clock out now?">Clock Out</button>
            }
        </form>
    </section>

    <div id="tn-confirm-modal" class="tn-confirm-modal" aria-hidden="true">
        <div class="tn-confirm-backdrop" data-close="true"></div>
        <div class="tn-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="tn-confirm-title" aria-describedby="tn-confirm-message">
            <h4 id="tn-confirm-title">Please confirm</h4>
            <p id="tn-confirm-message">Are you sure?</p>
            <div class="tn-confirm-actions">
                <button type="button" id="tn-confirm-ok" class="tn-primary-btn">Yes</button>
                <button type="button" id="tn-confirm-cancel" class="tn-outline-btn">Cancel</button>
            </div>
        </div>
    </div>

    <section class="tn-main-grid">
        <article class="tn-panel tn-chart-panel">
            <h3>Tracked Hours</h3>
            <div id="tn-hours-chart" class="tn-hours-chart" data-frame="day">
                @for (var i = 0; i < weekdays.Length; i++)
                {
                    var weekValue = i < Model.WeekDailyHours.Length ? Model.WeekDailyHours[i] : 0;
                    var dayValue = i == selectedDayIndex ? weekValue : 0;
                    <div class="tn-bar-row" data-day="@weekdays[i]" data-week="@weekValue.ToString("0.0")" data-dayval="@dayValue.ToString("0.0")"></div>
                }
            </div>
            <div class="tn-hours-meta">
                <div>
                    <span>Total Hours</span>
                    <strong id="tn-total-hours">@Model.TotalWorkedHours.ToString("0.0")h</strong>
                </div>
                <div>
                    <span>Overtime</span>
                    <strong id="tn-overtime">@Model.OvertimeHours.ToString("0.0")h</strong>
                </div>
                <div>
                    <span>Breaks</span>
                    <strong id="tn-breaks">@Model.TotalBreakHours.ToString("0.0")h</strong>
                </div>
            </div>
        </article>

        <article class="tn-panel tn-whosin">
            <h3>Who's In/Out</h3>
            <div class="tn-mini-stats">
                <div><strong>@Model.InCount</strong><span>In</span></div>
                <div><strong>@Model.BreakCount</strong><span>Break</span></div>
                <div><strong>@Model.OutCount</strong><span>Out</span></div>
            </div>
            <ul>
                @if (Model.TeamStatuses.Count == 0)
                {
                    <li><span class="dot out"></span> No team activity <em>Out</em></li>
                }
                else
                {
                    @foreach (var teamMember in Model.TeamStatuses)
                    {
                        var statusClass = teamMember.Status == "In" ? "in" : teamMember.Status == "Break" ? "break" : "out";
                        <li><span class="dot @statusClass"></span> @teamMember.FullName <em>@teamMember.Status</em></li>
                    }
                }
            </ul>
        </article>
    </section>

    <section class="tn-kpi-grid">
        <article class="tn-kpi-card">
            <span>Total Hours Tracked</span>
            <strong>@trackedHoursText h</strong>
            <small>Selected day</small>
        </article>
        <article class="tn-kpi-card">
            <span>Team Members</span>
            <strong>@Model.TeamMembersCount</strong>
            <small>Registered users</small>
        </article>
        <article class="tn-kpi-card">
            <span>Currently Clocked In</span>
            <strong class="tn-primary">@(currentlyClockedIn ? "1" : "0")</strong>
            <small>Current account</small>
        </article>
        <article class="tn-kpi-card">
            <span>Overtime</span>
            <strong class="tn-accent">@Model.WeekOvertimeHours.ToString("0.0")h</strong>
            <small>This week</small>
        </article>
    </section>

    <section class="tn-panel tn-activity-panel">
        <h3>Recent Time Entries</h3>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Timestamp (UTC)</th>
                        <th>Type</th>
                        <th>Project</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Entries.Count == 0)
                {
                    <tr>
                        <td colspan="4">No entries for the selected date.</td>
                    </tr>
                }
                else
                {
                    @foreach (var entry in Model.Entries)
                    {
                        <tr>
                            <td>@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@entry.EntryType</td>
                            <td>@entry.Project</td>
                            <td>@entry.Notes</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        (function () {
            const timeframeContainer = document.getElementById('tn-timeframe');
            const chart = document.getElementById('tn-hours-chart');
            const totalHours = document.getElementById('tn-total-hours');
            const overtime = document.getElementById('tn-overtime');
            const breaks = document.getElementById('tn-breaks');
            const confirmModal = document.getElementById('tn-confirm-modal');
            const confirmMessage = document.getElementById('tn-confirm-message');
            const confirmOk = document.getElementById('tn-confirm-ok');
            const confirmCancel = document.getElementById('tn-confirm-cancel');
            const entryTypeInput = document.getElementById('tn-entryType');
            const clockForm = document.querySelector('.tn-clock-actions');
            const dayWorked = @Model.TotalWorkedHours.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            const weekWorked = @Model.WeekTotalWorkedHours.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            const dayOvertime = @Model.OvertimeHours.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            const weekOvertime = @Model.WeekOvertimeHours.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            const dayBreaks = @Model.TotalBreakHours.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            const weekBreaks = @Model.WeekTotalBreakHours.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            let pendingEntryType = null;

            function closeConfirmModal() {
                if (!confirmModal) return;
                confirmModal.classList.remove('open');
                confirmModal.setAttribute('aria-hidden', 'true');
                pendingEntryType = null;
            }

            function openConfirmModal(entryType, message) {
                if (!confirmModal || !confirmMessage) return;
                pendingEntryType = entryType;
                confirmMessage.textContent = message;
                confirmModal.classList.add('open');
                confirmModal.setAttribute('aria-hidden', 'false');
            }

            function renderChart(frame) {
                if (!chart) return;
                chart.dataset.frame = frame;
                const rows = chart.querySelectorAll('.tn-bar-row');
                let total = 0;
                rows.forEach((row) => {
                    const value = parseFloat(frame === 'week' ? row.dataset.week : row.dataset.dayval);
                    total += value;
                    row.style.setProperty('--tn-val', String(Math.max(0, Math.min(10, value))));
                    row.setAttribute('data-label', frame === 'week' ? row.dataset.day : row.dataset.day + ' hour');
                });

                if (totalHours) totalHours.textContent = (frame === 'week' ? weekWorked : dayWorked).toFixed(1) + 'h';
                if (overtime) overtime.textContent = (frame === 'week' ? weekOvertime : dayOvertime).toFixed(1) + 'h';
                if (breaks) breaks.textContent = (frame === 'week' ? weekBreaks : dayBreaks).toFixed(1) + 'h';
            }

            function togglePills(container, onClick) {
                if (!container) return;
                container.querySelectorAll('button').forEach((btn) => {
                    btn.addEventListener('click', () => {
                        container.querySelectorAll('button').forEach((x) => x.classList.remove('active'));
                        btn.classList.add('active');
                        onClick(btn);
                    });
                });
            }

            togglePills(timeframeContainer, (btn) => renderChart(btn.dataset.frame || 'day'));
            renderChart('day');

            document.querySelectorAll('.tn-confirm-trigger').forEach((button) => {
                button.addEventListener('click', () => {
                    const entry = button.getAttribute('data-entry');
                    const message = button.getAttribute('data-message') || 'Are you sure?';
                    if (!entry) return;
                    openConfirmModal(entry, message);
                });
            });

            if (confirmOk) {
                confirmOk.addEventListener('click', () => {
                    if (!pendingEntryType || !entryTypeInput || !clockForm) {
                        closeConfirmModal();
                        return;
                    }
                    entryTypeInput.value = pendingEntryType;
                    clockForm.submit();
                });
            }

            if (confirmCancel) {
                confirmCancel.addEventListener('click', closeConfirmModal);
            }

            if (confirmModal) {
                confirmModal.addEventListener('click', (event) => {
                    const target = event.target;
                    if (target && target instanceof HTMLElement && target.dataset.close === 'true') {
                        closeConfirmModal();
                    }
                });
            }

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    closeConfirmModal();
                }
            });

            const clockEl = document.getElementById('tn-clock-time');
            const initialSeconds = Math.floor(@trackedSeconds);
            let seconds = initialSeconds;

            function formatTime(s) {
                const h = Math.floor(s / 3600).toString().padStart(2, '0');
                const m = Math.floor((s % 3600) / 60).toString().padStart(2, '0');
                const sec = Math.floor(s % 60).toString().padStart(2, '0');
                return h + ':' + m + ':' + sec;
            }

            function tick() {
                if (!clockEl) return;
                clockEl.textContent = formatTime(seconds);
                seconds += 1;
            }

            tick();
            const currentlyRunning = '@(currentlyClockedIn ? "true" : "false")' === 'true';
            if (currentlyRunning) {
                window.setInterval(tick, 1000);
            }
        })();
    </script>
}
