@model SimpleWebApp.ViewModels.WaitingApprovalViewModel

@{
    ViewData["Title"] = "Waiting For Approval";
    ViewData["FullWidth"] = true;
    ViewData["BodyClass"] = "tn-body-groups-page";
}

<section class="tn-choice-page-wrap">
    <div class="tn-choice-wrapper">
        <div class="tn-choice-header">
            <span class="tn-choice-kicker">Request Sent</span>
            <h1 class="tn-heading-lg">Waiting For Approval</h1>
            <p class="tn-text-muted">Your overseer request for <strong>@Model.GroupName</strong> is pending owner approval.</p>
        </div>

        <div class="tn-choice-recap-card">
            <div class="tn-choice-icon recap" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <h2 class="tn-heading-md">Approval in progress</h2>
            <p class="tn-text-muted">Requested on @Model.RequestedAt.ToString("MMM dd, yyyy HH:mm")</p>
            <p class="tn-choice-secondary-note">You can return later. Once approved, you can access the group as an overseer.</p>
            <div class="tn-form-actions">
                <a asp-controller="Group" asp-action="MyGroups" class="tn-btn tn-btn-outline">Back to My Groups</a>
            </div>
        </div>
    </div>
</section>

<style>
.tn-choice-page-wrap {
    min-height: calc(100vh - 126px);
    padding: clamp(1rem, 2.1vw, 1.8rem);
}

.tn-choice-wrapper {
    max-width: 980px;
    margin: 0 auto;
    padding: 2rem 1.5rem 2.5rem;
    border: 1px solid rgba(122, 162, 230, 0.35);
    border-radius: 1.2rem;
    background:
        radial-gradient(circle at 12% 0%, rgba(47, 111, 255, 0.14), transparent 30%),
        radial-gradient(circle at 90% 4%, rgba(6, 182, 212, 0.12), transparent 34%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(245, 251, 255, 0.82));
    box-shadow: 0 18px 34px rgba(31, 83, 171, 0.1);
}

.tn-choice-header {
    text-align: center;
    margin-bottom: 2rem;
}

.tn-choice-kicker {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(122, 162, 230, 0.45);
    background: rgba(255, 255, 255, 0.84);
    color: var(--tn-primary-strong);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.9rem;
}

.tn-choice-header h1 {
    margin-bottom: 0.45rem;
    font-size: clamp(2rem, 4vw, 2.8rem);
}

.tn-choice-recap-card {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
    padding: 2rem 1.8rem;
    border: 1px solid rgba(122, 162, 230, 0.45);
    border-radius: 1rem;
    text-align: center;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(4px);
}

.tn-choice-icon {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    margin-bottom: 0.8rem;
    color: white;
    box-shadow: 0 14px 24px rgba(33, 80, 166, 0.24);
}

.tn-choice-icon.recap {
    background: linear-gradient(135deg, var(--tn-primary), var(--tn-accent));
}

.tn-choice-secondary-note {
    margin: 0;
    color: var(--tn-muted);
    font-size: 0.92rem;
}
</style>
