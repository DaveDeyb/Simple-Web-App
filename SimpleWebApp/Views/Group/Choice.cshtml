@{
    ViewData["Title"] = "Get Started";
}

<div class="tn-container">
    <div class="tn-choice-wrapper">
        <div class="tn-choice-header">
            <h1 class="tn-heading-lg">Welcome to Time Nest!</h1>
            <p class="tn-text-muted">What would you like to do?</p>
        </div>

        <div class="tn-choice-grid">
            <!-- Create Group Option -->
            <div class="tn-choice-card tn-choice-create">
                <div class="tn-choice-icon create">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 5v14M5 12h14"></path>
                    </svg>
                </div>
                <h2 class="tn-heading-md">Create a Group</h2>
                <p class="tn-text-muted">Build a new team and manage members to track time together</p>
                <ul class="tn-choice-features">
                    <li>✓ Set up your team</li>
                    <li>✓ Generate invite codes</li>
                    <li>✓ Approve admins</li>
                    <li>✓ Manage members</li>
                </ul>
                <a asp-controller="Group" asp-action="Create" class="tn-btn tn-btn-primary tn-btn-lg">Create Group</a>
            </div>

            <!-- Join Group Option -->
            <div class="tn-choice-card tn-choice-join">
                <div class="tn-choice-icon join">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                        <path d="M16 11h6"></path>
                    </svg>
                </div>
                <h2 class="tn-heading-md">Join a Group</h2>
                <p class="tn-text-muted">Use an invite code to join an existing team as an overseer</p>
                <ul class="tn-choice-features">
                    <li>✓ Enter invite code</li>
                    <li>✓ Await group approval</li>
                    <li>✓ View team analytics</li>
                    <li>✓ Oversee members</li>
                </ul>
                <a asp-controller="Group" asp-action="Join" class="tn-btn tn-btn-secondary tn-btn-lg">Join Group</a>
            </div>
        </div>

        <div class="tn-choice-footer">
            <p class="tn-text-muted">
                Already have groups? <a asp-controller="Group" asp-action="MyGroups" class="tn-link">View my groups</a>
            </p>
        </div>
    </div>
</div>

<style>
.tn-choice-wrapper {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
}

.tn-choice-header {
    text-align: center;
    margin-bottom: 3rem;
}

.tn-choice-header h1 {
    margin-bottom: 0.5rem;
}

.tn-choice-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
}

.tn-choice-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem;
    border: 2px solid var(--tn-border);
    border-radius: 12px;
    text-align: center;
    transition: all 0.3s ease;
}

.tn-choice-card:hover {
    border-color: var(--tn-primary);
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.15);
    transform: translateY(-4px);
}

.tn-choice-icon {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    margin-bottom: 1.5rem;
    color: white;
}

.tn-choice-icon.create {
    background: linear-gradient(135deg, var(--tn-primary), #1e40af);
}

.tn-choice-icon.join {
    background: linear-gradient(135deg, var(--tn-accent), #0891b2);
}

.tn-choice-features {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    text-align: left;
    font-size: 0.95rem;
}

.tn-choice-features li {
    padding: 0.5rem 0;
    color: var(--tn-text-secondary);
}

.tn-btn-lg {
    padding: 0.75rem 2rem;
    font-size: 1rem;
    width: 100%;
    margin-top: 1rem;
}

.tn-choice-footer {
    text-align: center;
}

.tn-link {
    color: var(--tn-primary);
    text-decoration: none;
    font-weight: 500;
}

.tn-link:hover {
    text-decoration: underline;
}

@@media (max-width: 640px) {
    .tn-choice-wrapper {
        padding: 2rem 1rem;
    }

    .tn-choice-grid {
        gap: 1.5rem;
    }

    .tn-choice-card {
        padding: 1.5rem;
    }
}
</style>
