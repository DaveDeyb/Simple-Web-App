@model SimpleWebApp.ViewModels.GroupChoiceViewModel

@{
    ViewData["Title"] = "Get Started";
    ViewData["FullWidth"] = true;
    ViewData["BodyClass"] = "tn-body-groups-page";
}

<section class="tn-choice-page-wrap">
    <div class="tn-choice-wrapper">
        <div class="tn-choice-header">
            <span class="tn-choice-kicker">Admin Workspace</span>
            @if (Model.HasGroups)
            {
                <h1 class="tn-heading-lg">Your groups are ready</h1>
                <p class="tn-text-muted">You already manage @Model.GroupCount group@(Model.GroupCount == 1 ? "" : "s"). Open your workspace to view members and records.</p>
            }
            else
            {
                <h1 class="tn-heading-lg">Welcome to Time Nest!</h1>
                <p class="tn-text-muted">Choose your next move and keep your team flowing.</p>
            }
        </div>

        @if (Model.HasGroups)
        {
            <div class="tn-choice-recap-card">
                <div class="tn-choice-icon recap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 7h18M3 12h18M3 17h18"></path>
                        <circle cx="5" cy="7" r="1"></circle>
                        <circle cx="5" cy="12" r="1"></circle>
                        <circle cx="5" cy="17" r="1"></circle>
                    </svg>
                </div>
                <h2 class="tn-heading-md">Continue managing your groups</h2>
                <p class="tn-text-muted">Create or join another group from My Groups, or jump straight into your existing group records.</p>
                <a asp-controller="Group" asp-action="MyGroups" class="tn-btn tn-btn-primary tn-btn-lg tn-choice-primary-action">View My Groups</a>
                <p class="tn-choice-secondary-note">From there you can create new groups, join more teams, and open records for any group tile.</p>
            </div>
        }
        else
        {
            <div class="tn-choice-grid">
                <div class="tn-choice-card tn-choice-create">
                    <div class="tn-choice-icon create">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 5v14M5 12h14"></path>
                        </svg>
                    </div>
                    <h2 class="tn-heading-md">Create a Group</h2>
                    <p class="tn-text-muted">Build a fresh team space and manage members with confidence.</p>
                    <ul class="tn-choice-features">
                        <li>✓ Set up your team</li>
                        <li>✓ Generate invite codes</li>
                        <li>✓ Approve admins</li>
                        <li>✓ Manage members</li>
                    </ul>
                    <a asp-controller="Group" asp-action="Create" class="tn-btn tn-btn-primary tn-btn-lg">Create Group</a>
                </div>

                <div class="tn-choice-card tn-choice-join">
                    <div class="tn-choice-icon join">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                            <path d="M16 11h6"></path>
                        </svg>
                    </div>
                    <h2 class="tn-heading-md">Join a Group</h2>
                    <p class="tn-text-muted">Use an invite code to join an existing team as an overseer.</p>
                    <ul class="tn-choice-features">
                        <li>✓ Enter invite code</li>
                        <li>✓ Await group approval</li>
                        <li>✓ View team analytics</li>
                        <li>✓ Oversee members</li>
                    </ul>
                    <a asp-controller="Group" asp-action="Join" class="tn-btn tn-btn-outline tn-btn-lg">Join Group</a>
                </div>
            </div>
        }

    </div>
</section>

<style>
.tn-choice-page-wrap {
    min-height: calc(100vh - 126px);
    padding: clamp(1rem, 2.1vw, 1.8rem);
}

.tn-choice-wrapper {
    max-width: 980px;
    margin: 0 auto;
    padding: 2rem 1.5rem 2.5rem;
    border: 1px solid rgba(122, 162, 230, 0.35);
    border-radius: 1.2rem;
    background:
        radial-gradient(circle at 12% 0%, rgba(47, 111, 255, 0.14), transparent 30%),
        radial-gradient(circle at 90% 4%, rgba(6, 182, 212, 0.12), transparent 34%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(245, 251, 255, 0.82));
    box-shadow: 0 18px 34px rgba(31, 83, 171, 0.1);
}

.tn-choice-header {
    text-align: center;
    margin-bottom: 2rem;
}

.tn-choice-kicker {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(122, 162, 230, 0.45);
    background: rgba(255, 255, 255, 0.84);
    color: var(--tn-primary-strong);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.9rem;
}

.tn-choice-header h1 {
    margin-bottom: 0.45rem;
    font-size: clamp(2rem, 4vw, 2.8rem);
}

.tn-choice-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
}

.tn-choice-card,
.tn-choice-recap-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1.8rem;
    border: 1px solid rgba(122, 162, 230, 0.45);
    border-radius: 1rem;
    text-align: center;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(4px);
}

.tn-choice-card:hover,
.tn-choice-recap-card:hover {
    border-color: var(--tn-primary);
    box-shadow: 0 16px 28px rgba(37, 99, 235, 0.16);
    transform: translateY(-6px);
}

.tn-choice-recap-card {
    max-width: 640px;
    margin: 0 auto 2rem;
    gap: 0.9rem;
}

.tn-choice-icon {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    margin-bottom: 1.5rem;
    color: white;
    box-shadow: 0 14px 24px rgba(33, 80, 166, 0.24);
}

.tn-choice-icon.create {
    background: linear-gradient(135deg, var(--tn-primary), #1e40af);
}

.tn-choice-icon.join {
    background: linear-gradient(135deg, var(--tn-accent), #0891b2);
}

.tn-choice-icon.recap {
    background: linear-gradient(135deg, var(--tn-primary), var(--tn-accent));
}

.tn-choice-features {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    text-align: left;
    font-size: 0.95rem;
    width: 100%;
    max-width: 240px;
}

.tn-choice-features li {
    padding: 0.5rem 0;
    color: var(--tn-muted);
}

.tn-btn-lg {
    padding: 0.78rem 2rem;
    font-size: 1rem;
    width: 100%;
    margin-top: 1rem;
}

.tn-choice-primary-action {
    max-width: 260px;
}

.tn-choice-secondary-note {
    margin: 0;
    color: var(--tn-muted);
    font-size: 0.92rem;
}

@@media (max-width: 640px) {
    .tn-choice-page-wrap {
        min-height: calc(100vh - 132px);
        padding: 0.8rem;
    }

    .tn-choice-wrapper {
        padding: 1.4rem 0.9rem 1.6rem;
    }

    .tn-choice-grid {
        gap: 1.5rem;
    }

    .tn-choice-card,
    .tn-choice-recap-card {
        padding: 1.5rem;
    }
}
</style>
