@model SimpleWebApp.ViewModels.MyGroupsPageViewModel

@{
    ViewData["Title"] = "My Groups";
    ViewData["FullWidth"] = true;
    ViewData["BodyClass"] = "tn-body-groups-page";
}

<section class="tn-groups-page-wrap">
<div class="tn-groups-page-inner">
    <div class="tn-page-header">
        <div>
            <h1 class="tn-heading-lg">My Groups</h1>
            <p class="tn-text-muted">Manage and join groups to track time with your team</p>
        </div>
        <div class="tn-btn-group">
            @if (Model.IsUserAdmin)
            {
                <a asp-controller="Group" asp-action="Create" class="tn-btn tn-btn-primary tn-btn-lg">
                    <span class="tn-btn-icon">+</span> Create Group
                </a>
            }
            <a asp-controller="Group" asp-action="Join" class="tn-btn tn-btn-outline tn-btn-lg">Join Group</a>
        </div>
    </div>

    @if (Model.Groups.Count == 0)
    {
        <div class="tn-empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="tn-empty-icon">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <h2>No groups yet</h2>
            <p>
                @if (Model.IsUserAdmin)
                {
                    <span>Create or join a group to get started with team time tracking.</span>
                }
                else
                {
                    <span>Join a group to get started with team time tracking.</span>
                }
            </p>
        </div>
    }
    else
    {
        <div class="tn-grid" style="--columns: auto-fit; --min-width: 300px;">
            @foreach (var group in Model.Groups)
            {
                <div class="tn-card tn-card-hover">
                    <div class="tn-card-header">
                        <h3 class="tn-heading-md">@group.GroupName</h3>
                        <span class="tn-badge tn-badge-@(group.Role == SimpleWebApp.Models.Enums.GroupMemberRole.Admin ? "primary" : group.Role == SimpleWebApp.Models.Enums.GroupMemberRole.Overseer ? "accent" : "secondary")">
                            @group.Role
                        </span>
                    </div>
                    <p class="tn-text-muted">@group.GroupDescription</p>
                    <div class="tn-card-meta">
                        <small>👤 @group.OwnerName</small>
                        <small>👥 @group.MemberCount members</small>
                    </div>
                    <a asp-controller="Group" asp-action="Details" asp-route-id="@group.GroupId" class="tn-btn tn-btn-outline tn-btn-sm">View Details</a>
                </div>
            }
        </div>
    }
</div>
</section>

<style>
.tn-groups-page-wrap {
    min-height: calc(100vh - 126px);
    padding: clamp(1rem, 2.2vw, 1.75rem);
}

.tn-groups-page-inner {
    max-width: 100%;
    margin: 0 auto;
}

.tn-page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, var(--tn-primary-light, rgba(37, 99, 235, 0.05)) 0%, transparent 100%);
    border-radius: 12px;
    border-left: 4px solid var(--tn-primary);
}

.tn-page-header h1 {
    margin: 0 0 0.5rem 0;
}

.tn-btn-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.tn-btn-lg {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.3s ease;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.tn-btn-primary.tn-btn-lg {
    background: linear-gradient(135deg, var(--tn-primary) 0%, #1e40af 100%);
    color: white;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
}

.tn-btn-primary.tn-btn-lg:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(37, 99, 235, 0.4);
}

.tn-btn-outline.tn-btn-lg {
    background: #fff;
    border: 2px solid var(--tn-primary);
    color: var(--tn-primary);
}

.tn-btn-outline.tn-btn-lg:hover {
    background: var(--tn-primary-light, rgba(37, 99, 235, 0.05));
    transform: translateY(-2px);
}

.tn-btn-icon {
    font-size: 1.25rem;
    font-weight: 700;
}

.tn-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--min-width, 300px), 1fr));
    gap: 1.5rem;
}

.tn-card-hover {
    transition: transform 0.2s, box-shadow 0.2s;
}

.tn-card-hover:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
}

.tn-card-meta {
    display: flex;
    gap: 1rem;
    margin: 1rem 0;
    font-size: 0.875rem;
}

.tn-empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--tn-text-muted);
    border: 1px solid rgba(122, 162, 230, 0.35);
    border-radius: 1.1rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(243, 250, 255, 0.82));
    box-shadow: 0 14px 28px rgba(31, 83, 171, 0.08);
}

.tn-empty-icon {
    margin-bottom: 1rem;
    color: var(--tn-border);
}

.tn-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
}

.tn-badge-primary {
    background-color: var(--tn-primary);
    color: white;
}

.tn-badge-accent {
    background-color: var(--tn-accent);
    color: white;
}

.tn-badge-secondary {
    background-color: var(--tn-border);
    color: var(--tn-text);
}

@@media (max-width: 768px) {
    .tn-groups-page-wrap {
        min-height: calc(100vh - 132px);
        padding: 0.8rem;
    }

    .tn-page-header {
        flex-direction: column;
    }
    
    .tn-btn-group {
        width: 100%;
    }
    
    .tn-btn-group .tn-btn {
        flex: 1;
    }
}
</style>
