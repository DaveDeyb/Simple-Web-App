@{
    ViewData["Title"] = "Join Group";
    ViewData["FullWidth"] = true;
    ViewData["BodyClass"] = "tn-body-form-page";
}

<section class="tn-form-page-wrap">
    <div class="tn-form-page-inner">
        <section class="tn-form-scene">
            <div class="tn-form-inner">
                <span class="tn-form-kicker">Invite Access</span>
                <h1 class="tn-form-title">Join a Group</h1>
                <p class="tn-form-subtitle">Paste your invite code and jump into your team's shared tracking space.</p>

                <form asp-action="Join" method="post" class="tn-form-panel">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-2">
                        <label for="inviteCode" class="form-label fw-semibold">Invite Code <span class="text-danger">*</span></label>
                        <input type="text" id="inviteCode" name="inviteCode" class="form-control tn-input tn-code-input"
                               placeholder="ENTER 8-CHARACTER CODE" required maxlength="8" />
                        <small class="text-muted d-block mt-2">Ask your group admin for this code if you do not have it yet.</small>
                    </div>

                    <div class="tn-form-actions">
                        <button type="submit" class="tn-btn tn-btn-primary">Join Group</button>
                        <a asp-controller="@(ViewBag.CancelController ?? "Group")" asp-action="@(ViewBag.CancelAction ?? "MyGroups")" class="tn-btn tn-btn-outline">Cancel</a>
                    </div>

                    <p class="tn-form-note">For admin-created groups, your request may need owner approval before access is granted.</p>
                </form>
            </div>
        </section>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
