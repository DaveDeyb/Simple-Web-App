<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Time Nest</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SimpleWebApp.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var hideChrome = (ViewData["HideChrome"] as bool?) ?? false;
    }

    @if (!hideChrome)
    {
        <header>
            <nav class="tn-landing-nav tn-app-nav">
                <div class="tn-nav-left">
                    <a asp-controller="Home" asp-action="Index" class="tn-nav-brand">
                        <span class="tn-logo-mark"><img src="~/img/logo.svg" alt="Time Nest Logo" /></span>
                        <span>Time Nest</span>
                    </a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="tn-nav-left-links">
                            <a class="tn-nav-link" asp-controller="TimeEntries" asp-action="Index">Dashboard</a>
                            @if (User.HasClaim("IsAdmin", "true"))
                            {
                                <a class="tn-nav-link" asp-controller="Admin" asp-action="Index">Admin</a>
                            }
                        </div>
                    }
                </div>
                <div class="tn-nav-right">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form method="post" asp-controller="Account" asp-action="Logout">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="tn-btn tn-btn-primary">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a class="tn-nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="tn-btn tn-btn-primary" asp-controller="Account" asp-action="Register">Sign Up</a>
                    }
                </div>
            </nav>
        </header>
        <div class="tn-app-main">
            <main role="main" class="pb-3 tn-content-wrap">
                @RenderBody()
            </main>
        </div>

        <footer class="tn-landing-footer tn-app-footer">
            <div>
                &copy; 2026 Time Nest. All rights reserved.
            </div>
        </footer>
    }
    else
    {
        @RenderBody()
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
